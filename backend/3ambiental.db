import sqlite3
import os
from flask import Flask, render_template, request, redirect, jsonify
from werkzeug.utils import secure_filename

app = Flask(__name__, template_folder='../frontend', static_folder='../static')
UPLOAD_FOLDER = '../static/uploads'
app.config['UPLOAD_FOLDER'] = UPLOAD_FOLDER
DATABASE = '../database/ambiental.db'

# Função auxiliar para conectar ao banco
def get_db_connection():
    conn = sqlite3.connect(DATABASE)
    conn.row_factory = sqlite3.Row
    return conn

@app.route('/')
def index():
    return render_template('index.html')

@app.route('/registrar')
def pagina_registro():
    return render_template('registrar.html')

# ROTA PARA SALVAR NO BANCO
@app.route('/api/registrar', methods=['POST'])
def registrar_demanda():
    categoria = request.form.get('categoria')
    descricao = request.form.get('descricao')
    lat = request.form.get('latitude')
    lng = request.form.get('longitude')
    
    # Tratamento da Imagem
    file = request.files['foto']
    foto_url = ""
    if file:
        filename = secure_filename(file.filename)
        file.save(os.path.join(app.config['UPLOAD_FOLDER'], filename))
        foto_url = f"uploads/{filename}"
    
    # SALVANDO NO SQLITE
    conn = get_db_connection()
    conn.execute('''
        INSERT INTO demandas (categoria, descricao, latitude, longitude, foto_url)
        VALUES (?, ?, ?, ?, ?)
    ''', (categoria, descricao, lat, lng, foto_url))
    conn.commit()
    conn.close()
    
    return redirect('/')

# ROTA PARA O MAPA LER OS DADOS REAIS
@app.route('/api/ocorrencias')
def listar_ocorrencias():
    conn = get_db_connection()
    demandas = conn.execute('SELECT * FROM demandas').fetchall()
    conn.close()
    
    # Converte os dados do banco para o formato que o mapa entende (JSON)
    return jsonify([dict(ix) for ix in demandas])

if __name__ == '__main__':
    app.run(debug=True)
